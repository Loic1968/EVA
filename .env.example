# EVA – copie en .env et remplis les valeurs

# Base de données (obligatoire)
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# ou
EVA_DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Pour vérifier dev vs prod (npm run verify-schema)
# EVA_DATABASE_URL_PROD=postgresql://user:pass@prod-host:5432/dbname

# JWT (obligatoire pour auth)
EVA_JWT_SECRET=change-me-in-prod
# ou
JWT_SECRET=change-me-in-prod

# SMTP – mot de passe oublié (Gmail: mot de passe d'application)
SMTP_USER=ton-email@gmail.com
SMTP_PASS=abcd efgh ijkl mnop

# Frontend URL – OAuth redirect. EVA Vite utilise 3001 (pas 5173!)
# Vérifie le port affiché au démarrage: "Local: http://localhost:XXXX"
EVA_FRONTEND_URL=http://localhost:3001

# Optionnel – désactiver auth en dev
# EVA_SKIP_AUTH=true

# Gmail & Calendar OAuth (requis pour Data Sources → Connect Gmail)
# Google Cloud Console → Credentials → OAuth 2.0 Client ID
EVA_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
EVA_GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# API keys
# OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
