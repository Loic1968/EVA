{
  "name": "eva-digital-twin",
  "version": "0.1.0",
  "private": true,
  "description": "Project EVA – Personal AI Digital Twin. Independent app, same DB and stack as Halisoft.",
  "scripts": {
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "client": "cd web && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run client\"",
    "build": "npm run build:web",
    "build:web": "cd web && npm install --include=dev && npm run build",
    "start": "node server/index.js",
    "migrate": "node scripts/run-migrations.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test": "node --test server/__tests__/*.test.js",
    "test:unit": "node --test server/__tests__/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "openai": "^6.22.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "selenium-webdriver": "^4.41.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20"
  }
}
