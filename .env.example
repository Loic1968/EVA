# EVA — copy to .env and adjust
# DATABASE_URL from parent .env is used if EVA_DATABASE_URL not set

# Required for Chat + Document indexing
ANTHROPIC_API_KEY=sk-ant-...
# Or: CLAUDE_API_KEY=sk-ant-...
# Document indexing (PDF/images) uses Claude. If all docs fail: check key, set EVA_DOCUMENT_MODEL if needed.

# Optional: Voice (Whisper + TTS)
OPENAI_API_KEY=sk-...

# Optional: skip login in dev (uses EVA_OWNER_EMAIL as default user)
# EVA_SKIP_AUTH=true
# EVA_OWNER_EMAIL=you@example.com

# JWT (use strong secret in prod)
EVA_JWT_SECRET=change-me-in-production

# Optional: Web search (Tavily) — Chat + Voice
# TAVILY_API_KEY=tvly-...
# TAVILY_TIMEOUT_MS=10000  # default, override if needed

# Voice fluidity: low | medium | high (default medium = plus réactif)
# EVA_VOICE_EAGERNESS=medium
