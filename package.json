{
  "name": "eva-digital-twin",
  "version": "0.1.0",
  "private": true,
  "description": "Project EVA – Personal AI Digital Twin. Independent app, same DB and stack as Halisoft.",
  "scripts": {
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "client": "cd web && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run client\"",
    "build:web": "cd web && npm run build",
    "start": "node server/index.js",
    "test:smoke": "node scripts/smoke-test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20"
  }
}
