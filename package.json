{
  "name": "eva-digital-twin",
  "version": "0.1.0",
  "private": true,
  "description": "Project EVA – Personal AI Digital Twin. Independent app, same DB and stack as Halisoft.",
  "scripts": {
    "server": "EVA_PORT=5002 node server/index.js",
    "dev:server": "EVA_PORT=5002 node --watch server/index.js",
    "client": "cd web && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run client\"",
    "build": "npm run build:web",
    "build:web": "cd web && npm install --include=dev && npm run build",
    "start": "node scripts/run-migrations.js && node server/index.js",
    "migrate": "node scripts/run-migrations.js",
    "verify-schema": "node scripts/verify-schema.js",
    "test:smoke": "node scripts/smoke-test.js",
    "test:prod": "node scripts/prod-test.js",
    "diagnose:documents": "node scripts/diagnose-documents.js",
    "test:documents": "node scripts/test-document-processor.js",
    "test": "node --test server/__tests__/*.test.js",
    "test:unit": "node --test server/__tests__/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@simplewebauthn/server": "^13.2.3",
    "bcrypt": "^6.0.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "openai": "^6.22.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "selenium-webdriver": "^4.41.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20"
  }
}
