# Project EVA – same DB as Halisoft (use same DATABASE_URL or dedicated DB on same server)
DATABASE_URL=postgresql://user:password@localhost:5432/trade_finance2

# EVA API port (independent from Halisoft backend 5001)
EVA_PORT=5002
PORT=5002
NODE_ENV=development

# Claude API key for EVA chat (required)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override chat model (default: claude-sonnet-4-20250514)
# EVA_CHAT_MODEL=claude-sonnet-4-20250514

# Optional: API key for EVA web portal / mobile (single-owner for now)
EVA_API_KEY=

# Default owner (single-user mode)
EVA_OWNER_EMAIL=loic@halisoft.biz

# Optional: Halisoft API base if you want EVA to call Halisoft APIs later
# HALISOFT_API_BASE=http://localhost:5001

# --- Production (eva.halisoft.biz) ---
# EVA_PUBLIC_URL=https://eva.halisoft.biz
# VITE_EVA_API_URL=https://api.eva.halisoft.biz
