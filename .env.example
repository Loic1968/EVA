# EVA — copy to .env and adjust
# DATABASE_URL from parent .env is used if EVA_DATABASE_URL not set

# Required for Chat + Document indexing
ANTHROPIC_API_KEY=sk-ant-...
# Or: CLAUDE_API_KEY=sk-ant-...
# Document indexing (PDF/images) uses Claude. If all docs fail: check key, set EVA_DOCUMENT_MODEL if needed.

# Optional: Voice (Whisper + TTS)
OPENAI_API_KEY=sk-...

# Optional: skip login in dev (uses EVA_OWNER_EMAIL as default user)
# EVA_SKIP_AUTH=true
# EVA_OWNER_EMAIL=you@example.com

# JWT (use strong secret in prod)
EVA_JWT_SECRET=change-me-in-production

# Gmail/Calendar OAuth (optional — for sync, calendar)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# Or: EVA_GOOGLE_CLIENT_ID / EVA_GOOGLE_CLIENT_SECRET

# Personal tools (Calendar/Gmail) — tools-first for flight questions
# EVA_PERSONAL_TOOLS_ENABLED=true
# EVA_PERSONAL_TOOLS_DEBUG=true  # temp debug logging
# EVA_DEBUG=true  # general debug

# Optional: Web search (Tavily) — Chat + Voice
# TAVILY_API_KEY=tvly-...
# TAVILY_TIMEOUT_MS=10000  # default, override if needed

# Alice persona (executive assistant mode)
# EVA_ALICE_MODE=true  # global: all users get Alice persona
# Or use /alice on|off in chat for per-user toggle (stored in eva.settings)

# Voice fluidity: low | medium | high (default medium = plus réactif)
# EVA_VOICE_EAGERNESS=medium

# EVA 2 integration (persona + smart hybrid brain)
# EVA2_PERSONA=true          # Eva 2 guardrails in system prompt (default on)
# EVA_HYBRID_BRAIN=smart     # smart | true | false — smart = DeepSeek/Ollama only for bonjour, 中文, /local
# EVA_CHAT_MODEL=claude-sonnet-4-6
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# EVA_DEEPSEEK_MODEL=deepseek-chat
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:14b
# EVA_OLLAMA_ENABLED=true

# Eva 2 OpenClaw (VPS) — accès depuis EVA 1 /eva2
# EVA2_PUBLIC_URL=https://eva-vps.halisoft.biz
# EVA2_SSO_SECRET=          # même secret que sur le VPS (deploy/vps/.env)
